{
  "name": "logsnap",
  "version": "1.0.0",
  "description": "LogSnap is a mobile-first job logging assistant designed for field workers (electricians, fire protection, technicians). It simplifies job reporting by automatically capturing timestamps, location, and job activity, reducing manual input and improving accuracy.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "backend": "node --import tsx src/backend/server.ts",
    "backend:dev": "node --watch --import tsx src/backend/server.ts",
    "web": "expo start --web",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juswamacbook/LogSnap.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/juswamacbook/LogSnap/issues"
  },
  "homepage": "https://github.com/juswamacbook/LogSnap#readme",
  "dependencies": {
    "@react-navigation/native": "^7.2.0",
    "@react-navigation/native-stack": "^7.14.7",
    "cors": "^2.8.6",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-image-picker": "~17.0.10",
    "express": "^5.2.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "~19.1.10",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
